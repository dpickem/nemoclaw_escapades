# -----------------------------------------------------------------------
# HOST-SIDE ONLY — this file is read by the Makefile, never by the app.
#
# OpenShell path:  make setup-secrets  registers these with the gateway.
#                  The sandbox receives them via credential injection.
#
# Local dev path:  make run-local-dev   exports these into the shell.
#                  The app reads os.environ, not this file.
#
# This file MUST NOT enter the container image or the sandbox filesystem.
# -----------------------------------------------------------------------

# Required — Slack bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=

# Required — Slack app-level token for socket mode (xapp-...)
SLACK_APP_TOKEN=

# Required — NVIDIA Inference Hub API key
# OpenShell injects this via the inference.local proxy — the sandbox
# code never sees the raw key.  Set here for make setup-secrets only.
INFERENCE_HUB_API_KEY=

# Required — Base URL for the inference API (OpenAI-compatible /v1 endpoint)
INFERENCE_HUB_BASE_URL=

# Optional — Model name (default: azure/anthropic/claude-opus-4-6)
# INFERENCE_MODEL=azure/anthropic/claude-opus-4-6

# Optional — Timeout for inference calls in seconds (default: 60)
# INFERENCE_TIMEOUT_S=60

# Optional — Max retry attempts for transient failures (default: 3)
# INFERENCE_MAX_RETRIES=3

# Optional — Logging level (default: INFO)
# LOG_LEVEL=INFO

# Optional — Path to log file (default: stdout only)
# LOG_FILE=

# Optional — Path to system prompt file (default: prompts/system_prompt.md)
# SYSTEM_PROMPT_PATH=prompts/system_prompt.md

# Optional — Max messages per thread history (default: 50)
# MAX_THREAD_HISTORY=50

# ---------------------------------------------------------------------------
# nv-tools — build (optional, only needed for internal builds)
# ---------------------------------------------------------------------------

# Git repo URL for the real nv-tools CLI (without https:// prefix).
# Used by `make build NV_TOOLS_SOURCE=gitlab` to pip-install from source.
# Not needed when using the stub (default).
# NV_TOOLS_REPO_URL=

# GitLab personal access token for cloning the nv-tools repo.
# NV_TOOLS_GITLAB_TOKEN=

# ---------------------------------------------------------------------------
# nv-tools — service credentials (optional, only needed with real nv-tools)
#
# These are injected into the sandbox via a single OpenShell provider
# (`nv-tools-credentials`).  See the nv-tools integration design doc §6.
# When using the stub, these are ignored.
# ---------------------------------------------------------------------------

# Jira
# JIRA_URL=
# JIRA_USERNAME=
# JIRA_API_TOKEN=

# Confluence
# CONFLUENCE_URL=
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=

# GitLab
# GITLAB_URL=
# GITLAB_TOKEN=

# Gerrit
# GERRIT_URL=
# GERRIT_USERNAME=
# GERRIT_HTTP_PASSWORD=

# Slack (user OAuth token — xoxp-..., NOT bot token)
# SLACK_USER_TOKEN=
