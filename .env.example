# -----------------------------------------------------------------------
# HOST-SIDE ONLY — this file is read by the Makefile, never by the app.
#
# OpenShell path:  make setup-secrets  registers these with the gateway.
#                  The sandbox receives them via credential injection.
#
# Local dev path:  make run-local-dev   exports these into the shell.
#                  The app reads os.environ, not this file.
#
# This file MUST NOT enter the container image or the sandbox filesystem.
# -----------------------------------------------------------------------

# Required — Slack bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=

# Required — Slack app-level token for socket mode (xapp-...)
SLACK_APP_TOKEN=

# Required — NVIDIA Inference Hub API key
# OpenShell injects this via the inference.local proxy — the sandbox
# code never sees the raw key.  Set here for make setup-secrets only.
INFERENCE_HUB_API_KEY=

# Required — Base URL for the inference API (OpenAI-compatible /v1 endpoint)
INFERENCE_HUB_BASE_URL=

# Optional — Inference-backend default model (default: azure/anthropic/claude-opus-4-6)
# The orchestrator uses the same model by default; set
# ORCHESTRATOR_MODEL to run the orchestrator on something different.
# INFERENCE_MODEL=azure/anthropic/claude-opus-4-6

# Optional — Orchestrator-only model override.  Wins over the
# INFERENCE_MODEL-induced propagation so an operator can pin the
# orchestrator to a specific model while the rest of the inference
# backend defaults to INFERENCE_MODEL.  Loop sub-agents are tuned
# separately via ``config.agent_loop.model`` in YAML.
# ORCHESTRATOR_MODEL=azure/anthropic/claude-opus-4-6

# Optional — Timeout for inference calls in seconds (default: 60)
# INFERENCE_TIMEOUT_S=60

# Optional — Max retry attempts for transient failures (default: 3)
# INFERENCE_MAX_RETRIES=3

# Optional — Logging level (default: INFO)
# LOG_LEVEL=INFO

# Optional — Path to log file (default: stdout only)
# LOG_FILE=

# Optional — Path to system prompt file (default: prompts/system_prompt.md)
# SYSTEM_PROMPT_PATH=prompts/system_prompt.md

# Optional — Max messages per thread history (default: 50)
# MAX_THREAD_HISTORY=50

# ---------------------------------------------------------------------------
# Agent loop — per-``AgentLoop`` runtime knobs
#
# These control the reusable loop (shared by the orchestrator and the
# coding sub-agent), not the orchestrator's prompting fields above.
# The loop's ``model`` / ``temperature`` / ``max_tokens`` default to
# the same values as the orchestrator; set them separately here only
# if a sub-agent needs a different configuration.
# ---------------------------------------------------------------------------

# Safety limit: max inference calls per run (default: 10)
# AGENT_LOOP_MAX_TOOL_ROUNDS=10

# How many times to re-prompt when finish_reason="length" (default: 2)
# AGENT_LOOP_MAX_CONTINUATION_RETRIES=2

# Tool-result chars above which micro-compaction truncates (default: 10000)
# AGENT_LOOP_MICRO_COMPACTION_CHARS=10000

# Total message chars that trigger full compaction (default: 400000)
# AGENT_LOOP_COMPACTION_THRESHOLD_CHARS=400000

# Fraction of oldest messages to summarise (default: 0.5)
# AGENT_LOOP_COMPACTION_COMPRESS_RATIO=0.5

# Minimum messages to keep verbatim after compaction (default: 4)
# AGENT_LOOP_COMPACTION_MIN_KEEP=4

# ---------------------------------------------------------------------------
# NMB client — broker URL and sandbox identity
#
# These are category-A non-secret config; they flow through the YAML
# overlay (``nmb:`` section in ``config/defaults.yaml``) in the
# sandbox.  Override here for local-dev runs that stand up their own
# broker or want to pin a sandbox identity.
# ---------------------------------------------------------------------------

# WebSocket URL of the NMB broker (default: ws://messages.local:9876)
# NMB_URL=ws://localhost:9876

# Stable sandbox identity announced to the broker.  Empty = the agent
# generates a per-process id at startup.
# AGENT_SANDBOX_ID=coding-local

# ---------------------------------------------------------------------------
# Jira — direct REST API integration
# ---------------------------------------------------------------------------

# Jira instance URL (default: https://jirasw.nvidia.com)
# JIRA_URL=https://jirasw.nvidia.com

# Pre-computed Authorization header: "Basic base64(username:api_token)"
# Generate: echo -n "USERNAME:API_TOKEN" | base64
# In the sandbox, this is resolved by the OpenShell L7 proxy from the
# jira-credentials provider.  Locally, set the real value here.
# JIRA_AUTH=Basic ...

# ---------------------------------------------------------------------------
# GitLab — REST API v4 integration
# ---------------------------------------------------------------------------

# GitLab instance URL.  Category-B (private non-secret): the public
# repo ships no default; set this to your GitLab hostname.  Locally,
# it flows through the env var at runtime.  In the sandbox,
# `make gen-config` merges this value into `/app/config.yaml`'s
# `toolsets.gitlab.url` at build time (see docs/design_m2b.md §5.3).
# GITLAB_URL=https://gitlab.example.com

# Personal Access Token (PAT) with api scope — sent as Bearer auth
# GITLAB_TOKEN=glpat-...

# ---------------------------------------------------------------------------
# Gerrit — REST API integration
# ---------------------------------------------------------------------------

# Gerrit instance URL.  Category-B — same handling as GITLAB_URL.
# GERRIT_URL=https://gerrit.example.com/r/a

# Gerrit HTTP credentials (Settings > HTTP Credentials)
# GERRIT_USERNAME=
# GERRIT_HTTP_PASSWORD=

# ---------------------------------------------------------------------------
# Confluence — REST API integration
# ---------------------------------------------------------------------------

# Confluence instance URL
# CONFLUENCE_URL=https://nvidia.atlassian.net/wiki

# Atlassian account email and API token
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=

# ---------------------------------------------------------------------------
# Slack user token — search, history, and user-token operations
# (separate from SLACK_BOT_TOKEN used by the connector)
# ---------------------------------------------------------------------------

# Slack user OAuth token (xoxp-...) with search:read, channels:read,
# channels:history, users:read scopes
# SLACK_USER_TOKEN=xoxp-...

# ---------------------------------------------------------------------------
# Web Search — Brave Search API (web_search / web_fetch tools)
# ---------------------------------------------------------------------------

# Brave Search API key (get one at https://brave.com/search/api/)
# Required for web_search; web_fetch works without it.
# BRAVE_SEARCH_API_KEY=

# Jina Reader API key (optional — free tier works without one at 20 RPM).
# Get a free key with 10M tokens at https://jina.ai/reader/ to raise
# the limit to 500 RPM.
# JINA_API_KEY=

# Default number of search results returned (default: 5)
# WEB_SEARCH_DEFAULT_LIMIT=5

# ---------------------------------------------------------------------------
# GitHub — used by gh CLI and GitHub API tools
# ---------------------------------------------------------------------------

# GitHub Personal Access Token (classic or fine-grained)
# GITHUB_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Coding agent — git_clone host allowlist
# ---------------------------------------------------------------------------

# Comma-separated hostnames git_clone is permitted to clone from.
# Category-B (private non-secret): an empty value is **fail-closed** —
# the tool refuses every URL.  Set this to opt in.
#
# Local dev (`make run-local-dev`):  read directly from this env var
#   at runtime via `AppConfig.load()`.
# Sandbox (`make run-local-sandbox`): `make gen-config` reads this
#   value from `.env` and merges it into
#   `config/orchestrator.resolved.yaml:coding.git_clone_allowed_hosts`,
#   which the Dockerfile COPYs to `/app/config.yaml`.  See
#   `docs/design_m2b.md` §5.3 for the resolver design.
# GIT_CLONE_ALLOWED_HOSTS=gitlab.example.com,gerrit.example.com,github.com

# ---------------------------------------------------------------------------
# Sandbox policy — internal service SSRF bypass
# ---------------------------------------------------------------------------

# Comma-separated CIDRs for internal services that resolve to RFC 1918 IPs.
# Required for GitLab and Gerrit to work inside the OpenShell sandbox.
# Find IPs with: dig +short <gitlab-host> <gerrit-host>
# ALLOWED_IPS=10.x.x.0/24,10.y.y.0/24

# Comma-separated hostnames that require allowed_ips injection.
# Must be set alongside ALLOWED_IPS for sandbox SSRF bypass to work.
ENDPOINTS_NEEDING_ALLOWED_IPS=

# ---------------------------------------------------------------------------
# Audit DB — tool-call logging for debugging and training data
# ---------------------------------------------------------------------------

# Enable/disable audit logging (default: true)
# AUDIT_ENABLED=true

# Path to the SQLite audit DB.
# Sandbox default: /sandbox/audit.db  (PVC-backed, persistent across restarts)
# Local default:   ~/.nemoclaw/audit.db
# AUDIT_DB_PATH=~/.nemoclaw/audit.db

# Store full request/response payloads (default: true).
# Set to false for privacy-sensitive deployments.
# AUDIT_PERSIST_PAYLOADS=true
