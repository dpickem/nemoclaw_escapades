# -----------------------------------------------------------------------
# HOST-SIDE ONLY — this file is read by the Makefile, never by the app
# inside the sandbox.
#
# OpenShell path:  make setup-secrets  registers these with the gateway.
#                  The sandbox receives them as L7-proxy placeholder
#                  env vars, which the proxy resolves at HTTP-request
#                  time.  The app only ever sees placeholders.
#
# Runtime config split:
#   - .env        → **secrets only** (this file).  Tokens, API keys,
#                   usernames, passwords, and category-B private
#                   values consumed by the `make gen-config` /
#                   `make gen-policy` resolvers at build time.
#   - config/*.yaml → every non-secret knob (models, URLs, paths,
#                   feature flags, agent-loop parameters).  Edit
#                   `config/defaults.yaml` to change behaviour.
#
# This file MUST NOT enter the container image or the sandbox filesystem.
# -----------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Secrets — OpenShell-provider-injected placeholders in the sandbox
# ---------------------------------------------------------------------------

# Required — Slack bot OAuth token (xoxb-...).  Needed by the
# orchestrator's SlackConnector; the coding sub-agent skips this check.
SLACK_BOT_TOKEN=

# Required — Slack app-level token for socket mode (xapp-...).
SLACK_APP_TOKEN=

# Required — NVIDIA Inference Hub API key.  OpenShell injects this via
# the inference.local proxy — the sandbox code never sees the raw key.
INFERENCE_HUB_API_KEY=

# Jira — pre-computed "Basic base64(USERNAME:API_TOKEN)" header.
# Generate: echo -n "USERNAME:API_TOKEN" | base64
# JIRA_AUTH=Basic ...

# GitLab — personal access token (api scope) sent as Bearer auth.
# GITLAB_TOKEN=glpat-...

# Gerrit — HTTP credentials (Settings → HTTP Credentials).
# GERRIT_USERNAME=
# GERRIT_HTTP_PASSWORD=

# Confluence — Atlassian account email + API token.
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=

# Slack user OAuth token (xoxp-...) with search:read, channels:read,
# channels:history, users:read scopes.  Separate from SLACK_BOT_TOKEN.
# SLACK_USER_TOKEN=xoxp-...

# Brave Search API key (https://brave.com/search/api/).  Required for
# web_search; web_fetch works without it.
# BRAVE_SEARCH_API_KEY=

# Jina Reader API key (optional — free tier works without one at 20 RPM).
# Free key with 10M tokens at https://jina.ai/reader/ → 500 RPM.
# JINA_API_KEY=

# GitHub Personal Access Token (classic or fine-grained).  Used by the
# gh CLI and GitHub API tools.
# GITHUB_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Category-B private values — consumed at build time only
#
# Not secrets, but also not in public source.  `make gen-config` /
# `make gen-policy` read these and bake them into the resolved YAML /
# policy files that the Dockerfile COPYs into the sandbox image.
# The app at runtime reads the YAML, not these env vars.
# ---------------------------------------------------------------------------

# GitLab instance URL.  Resolver fills `toolsets.gitlab.url` in
# `config/orchestrator.resolved.yaml` and
# `network_policies.gitlab.endpoints[0].host` in
# `policies/orchestrator.resolved.yaml`.
# GITLAB_URL=https://gitlab.example.com

# Gerrit instance URL.  Same handling as GITLAB_URL.
# GERRIT_URL=https://gerrit.example.com/r/a

# ---------------------------------------------------------------------------
# Sandbox policy — SSRF bypass for internal endpoints
#
# Committed `policies/orchestrator.yaml` ships empty `host: ""`
# placeholders.  `make gen-policy` performs two substitutions:
#   1. Hostname from GITLAB_URL / GERRIT_URL → endpoint.host.
#   2. allowed_ips from ALLOWED_IPS (+ ENDPOINTS_NEEDING_ALLOWED_IPS
#      to pick the host list).
# Empty → resolved policy is fail-closed (OpenShell rejects empty-host
# endpoints at apply time).
# ---------------------------------------------------------------------------

# Comma-separated CIDRs for internal services that resolve to RFC 1918 IPs.
# Required for GitLab and Gerrit to work inside the OpenShell sandbox.
# Find IPs with: dig +short <gitlab-host> <gerrit-host>
# ALLOWED_IPS=10.x.x.0/24,10.y.y.0/24

# Comma-separated hostnames that require allowed_ips injection.  Must
# match the hostnames derived from GITLAB_URL / GERRIT_URL.
ENDPOINTS_NEEDING_ALLOWED_IPS=

# Comma-separated hostnames git_clone is permitted to clone from.
# Category-B: fail-closed when empty.  `make gen-config` reads this
# and writes it into `coding.git_clone_allowed_hosts` in the resolved
# YAML.
# GIT_CLONE_ALLOWED_HOSTS=gitlab.example.com,gerrit.example.com,github.com
